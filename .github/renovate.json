{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true,
    "automerge": true,
    "extends": ["schedule:daily"]
  },
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "extends": ["schedule:daily"]
    }
  ]
}
